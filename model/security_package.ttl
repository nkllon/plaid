<https://nkllon.com/plaid/security-doc/document/incident-response-policy/section/6/block/1/item/1> a secdoc:ListItem ;
    secdoc:itemOrder 1 ;
    secdoc:text "Disable or rotate affected credentials." .

<https://nkllon.com/plaid/security-doc/document/incident-response-policy/section/6/block/1/item/2> a secdoc:ListItem ;
    secdoc:itemOrder 2 ;
    secdoc:text "Restrict repository, deployment, or cloud access as needed." .

<https://nkllon.com/plaid/security-doc/document/incident-response-policy/section/6/block/1/item/3> a secdoc:ListItem ;
    secdoc:itemOrder 3 ;
    secdoc:text "Pause affected integrations or deployments when active compromise is suspected." .

<https://nkllon.com/plaid/security-doc/document/incident-response-policy/section/6/block/1/item/4> a secdoc:ListItem ;
    secdoc:itemOrder 4 ;
