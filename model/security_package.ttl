    secdoc:itemOrder 3 ;
    secdoc:text "CI workflows help detect syntax, test, packaging, and some security failures before merge." .

<https://nkllon.com/plaid/security-doc/document/open-source-security-model/section/2/block/1/item/4> a secdoc:ListItem ;
    secdoc:itemOrder 4 ;
    secdoc:text "Dependency automation and scanning features can surface known vulnerable packages earlier than manual review alone." .

<https://nkllon.com/plaid/security-doc/document/open-source-security-model/section/3> a secdoc:Section ;
    secdoc:hasBlock <https://nkllon.com/plaid/security-doc/document/open-source-security-model/section/3/block/1> ;
    secdoc:headingLevel 2 ;
    secdoc:sectionOrder 3 ;
    secdoc:title "Limits of the model" .

<https://nkllon.com/plaid/security-doc/document/open-source-security-model/section/3/block/1> a secdoc:ListBlock ;
    secdoc:blockOrder 1 ;
    secdoc:hasItem <https://nkllon.com/plaid/security-doc/document/open-source-security-model/section/3/block/1/item/1>,
        <https://nkllon.com/plaid/security-doc/document/open-source-security-model/section/3/block/1/item/2>,
        <https://nkllon.com/plaid/security-doc/document/open-source-security-model/section/3/block/1/item/3> ;
    secdoc:isOrdered false .

<https://nkllon.com/plaid/security-doc/document/open-source-security-model/section/3/block/1/item/1> a secdoc:ListItem ;
    secdoc:itemOrder 1 ;
    secdoc:text "Public visibility does not replace formal internal segregation of duties." .

<https://nkllon.com/plaid/security-doc/document/open-source-security-model/section/3/block/1/item/2> a secdoc:ListItem ;
    secdoc:itemOrder 2 ;
    secdoc:text "Open source review is opportunistic; not every change receives expert external security review." .

<https://nkllon.com/plaid/security-doc/document/open-source-security-model/section/3/block/1/item/3> a secdoc:ListItem ;
    secdoc:itemOrder 3 ;
    secdoc:text "Security maturity varies across repositories and older repositories may not implement the same controls as newer projects." .

<https://nkllon.com/plaid/security-doc/document/open-source-security-model/section/4> a secdoc:Section ;
    secdoc:hasBlock <https://nkllon.com/plaid/security-doc/document/open-source-security-model/section/4/block/1> ;
    secdoc:headingLevel 2 ;
    secdoc:sectionOrder 4 ;
    secdoc:title "Public repository rules" .

<https://nkllon.com/plaid/security-doc/document/open-source-security-model/section/4/block/1> a secdoc:ListBlock ;
    secdoc:blockOrder 1 ;
    secdoc:hasItem <https://nkllon.com/plaid/security-doc/document/open-source-security-model/section/4/block/1/item/1>,
        <https://nkllon.com/plaid/security-doc/document/open-source-security-model/section/4/block/1/item/2>,
        <https://nkllon.com/plaid/security-doc/document/open-source-security-model/section/4/block/1/item/3>,
        <https://nkllon.com/plaid/security-doc/document/open-source-security-model/section/4/block/1/item/4> ;
    secdoc:isOrdered false .

<https://nkllon.com/plaid/security-doc/document/open-source-security-model/section/4/block/1/item/1> a secdoc:ListItem ;
    secdoc:itemOrder 1 ;
    secdoc:text "No sensitive financial credentials or personal financial data are stored in public repositories." .

<https://nkllon.com/plaid/security-doc/document/open-source-security-model/section/4/block/1/item/2> a secdoc:ListItem ;
    secdoc:itemOrder 2 ;
    secdoc:text "Public repositories may include templates, placeholders, sample values, and integration documentation, but not live production secrets." .

<https://nkllon.com/plaid/security-doc/document/open-source-security-model/section/4/block/1/item/3> a secdoc:ListItem ;
    secdoc:itemOrder 3 ;
    secdoc:text "Operational secrets must be injected at runtime or stored in managed secret systems." .

<https://nkllon.com/plaid/security-doc/document/open-source-security-model/section/4/block/1/item/4> a secdoc:ListItem ;
    secdoc:itemOrder 4 ;
    secdoc:text "Plaid-connected runtimes, access tokens, account data, and derived financial records are outside the scope of public source control and must remain in controlled runtime environments." .

<https://nkllon.com/plaid/security-doc/document/open-source-security-model/section/5> a secdoc:Section ;
    secdoc:hasBlock <https://nkllon.com/plaid/security-doc/document/open-source-security-model/section/5/block/1> ;
    secdoc:headingLevel 2 ;
    secdoc:sectionOrder 5 ;
    secdoc:title "Review and contribution model" .

<https://nkllon.com/plaid/security-doc/document/open-source-security-model/section/5/block/1> a secdoc:ListBlock ;
