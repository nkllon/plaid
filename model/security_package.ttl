<https://nkllon.com/plaid/security-doc/document/readme/section/7/block/1/item/1> a secdoc:ListItem ;
    secdoc:itemOrder 1 ;
    secdoc:text "Public repositories in scope are documentation, code, and configuration-template artifacts only." .

<https://nkllon.com/plaid/security-doc/document/readme/section/7/block/1/item/2> a secdoc:ListItem ;
    secdoc:itemOrder 2 ;
    secdoc:text "Any Plaid-connected runtime environment must keep client secrets, access tokens, item identifiers, account data, transaction data, and derived financial records outside public source control." .

<https://nkllon.com/plaid/security-doc/document/readme/section/7/block/1/item/3> a secdoc:ListItem ;
    secdoc:itemOrder 3 ;
    secdoc:text "Plaid or equivalent financial integrations must run only in controlled runtime environments that use managed secret storage and authenticated access paths." .

