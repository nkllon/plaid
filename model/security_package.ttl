    secdoc:partOfPackage <https://nkllon.com/plaid/security-doc/package/plaid-security-package> ;
    secdoc:title "Access Control Policy" .

<https://nkllon.com/plaid/security-doc/document/access-control-policy/section/1> a secdoc:Section ;
    secdoc:hasBlock <https://nkllon.com/plaid/security-doc/document/access-control-policy/section/1/block/1> ;
    secdoc:headingLevel 2 ;
    secdoc:sectionOrder 1 ;
    secdoc:title "Purpose" .

<https://nkllon.com/plaid/security-doc/document/access-control-policy/section/1/block/1> a secdoc:ParagraphBlock ;
    secdoc:blockOrder 1 ;
    secdoc:text "This policy defines access control expectations for source code, deployment systems, secrets, and administrative functions." .

<https://nkllon.com/plaid/security-doc/document/access-control-policy/section/2> a secdoc:Section ;
    secdoc:hasBlock <https://nkllon.com/plaid/security-doc/document/access-control-policy/section/2/block/1> ;
    secdoc:headingLevel 2 ;
    secdoc:sectionOrder 2 ;
    secdoc:title "Identity and authentication" .

<https://nkllon.com/plaid/security-doc/document/access-control-policy/section/2/block/1> a secdoc:ListBlock ;
    secdoc:blockOrder 1 ;
    secdoc:hasItem <https://nkllon.com/plaid/security-doc/document/access-control-policy/section/2/block/1/item/1>,
        <https://nkllon.com/plaid/security-doc/document/access-control-policy/section/2/block/1/item/2>,
        <https://nkllon.com/plaid/security-doc/document/access-control-policy/section/2/block/1/item/3>,
        <https://nkllon.com/plaid/security-doc/document/access-control-policy/section/2/block/1/item/4> ;
    secdoc:isOrdered false .

<https://nkllon.com/plaid/security-doc/document/access-control-policy/section/2/block/1/item/1> a secdoc:ListItem ;
    secdoc:itemOrder 1 ;
    secdoc:text "GitHub is the system of record for source repository access." .

<https://nkllon.com/plaid/security-doc/document/access-control-policy/section/2/block/1/item/2> a secdoc:ListItem ;
    secdoc:itemOrder 2 ;
    secdoc:text "Each user must authenticate with an individual GitHub account. Shared accounts are not permitted." .

<https://nkllon.com/plaid/security-doc/document/access-control-policy/section/2/block/1/item/3> a secdoc:ListItem ;
    secdoc:itemOrder 3 ;
    secdoc:text "Administrative and write access must be limited to the maintainer and explicitly authorized collaborators only." .

<https://nkllon.com/plaid/security-doc/document/access-control-policy/section/2/block/1/item/4> a secdoc:ListItem ;
    secdoc:itemOrder 4 ;
    secdoc:text "Multi-factor authentication is required on GitHub accounts with administrative or write access." .

<https://nkllon.com/plaid/security-doc/document/access-control-policy/section/3> a secdoc:Section ;
    secdoc:hasBlock <https://nkllon.com/plaid/security-doc/document/access-control-policy/section/3/block/1> ;
    secdoc:headingLevel 2 ;
    secdoc:sectionOrder 3 ;
    secdoc:title "Repository permission model" .

<https://nkllon.com/plaid/security-doc/document/access-control-policy/section/3/block/1> a secdoc:ListBlock ;
    secdoc:blockOrder 1 ;
    secdoc:hasItem <https://nkllon.com/plaid/security-doc/document/access-control-policy/section/3/block/1/item/1>,
        <https://nkllon.com/plaid/security-doc/document/access-control-policy/section/3/block/1/item/2>,
        <https://nkllon.com/plaid/security-doc/document/access-control-policy/section/3/block/1/item/3>,
        <https://nkllon.com/plaid/security-doc/document/access-control-policy/section/3/block/1/item/4> ;
    secdoc:isOrdered false .

<https://nkllon.com/plaid/security-doc/document/access-control-policy/section/3/block/1/item/1> a secdoc:ListItem ;
    secdoc:itemOrder 1 ;
    secdoc:text "Public repositories are readable by anyone and are treated as non-secret by design." .

<https://nkllon.com/plaid/security-doc/document/access-control-policy/section/3/block/1/item/2> a secdoc:ListItem ;
    secdoc:itemOrder 2 ;
    secdoc:text "Private repositories are used for operational details, deployment configurations, or integrations that must not be publicly exposed." .

<https://nkllon.com/plaid/security-doc/document/access-control-policy/section/3/block/1/item/3> a secdoc:ListItem ;
    secdoc:itemOrder 3 ;
    secdoc:text "Access to private repositories must be granted on least-privilege principles." .

<https://nkllon.com/plaid/security-doc/document/access-control-policy/section/3/block/1/item/4> a secdoc:ListItem ;
    secdoc:itemOrder 4 ;
    secdoc:text "Administrative privileges must be limited to the repository owner and only to accounts necessary to maintain the repository." .

<https://nkllon.com/plaid/security-doc/document/access-control-policy/section/4> a secdoc:Section ;
    secdoc:hasBlock <https://nkllon.com/plaid/security-doc/document/access-control-policy/section/4/block/1>,
        <https://nkllon.com/plaid/security-doc/document/access-control-policy/section/4/block/2>,
        <https://nkllon.com/plaid/security-doc/document/access-control-policy/section/4/block/3>,
        <https://nkllon.com/plaid/security-doc/document/access-control-policy/section/4/block/4> ;
    secdoc:headingLevel 2 ;
    secdoc:sectionOrder 4 ;
    secdoc:title "Pull requests and branch protection" .

<https://nkllon.com/plaid/security-doc/document/access-control-policy/section/4/block/1> a secdoc:ParagraphBlock ;
    secdoc:blockOrder 1 ;
    secdoc:text "Observed examples:" .

<https://nkllon.com/plaid/security-doc/document/access-control-policy/section/4/block/2> a secdoc:ListBlock ;
    secdoc:blockOrder 2 ;
    secdoc:hasItem <https://nkllon.com/plaid/security-doc/document/access-control-policy/section/4/block/2/item/1>,
        <https://nkllon.com/plaid/security-doc/document/access-control-policy/section/4/block/2/item/2>,
        <https://nkllon.com/plaid/security-doc/document/access-control-policy/section/4/block/2/item/3>,
        <https://nkllon.com/plaid/security-doc/document/access-control-policy/section/4/block/2/item/4> ;
    secdoc:isOrdered false .

<https://nkllon.com/plaid/security-doc/document/access-control-policy/section/4/block/2/item/1> a secdoc:ListItem ;
    secdoc:itemOrder 1 ;
    secdoc:text "nkllon/gorgonaut has branch protection on main, administrator enforcement enabled, force pushes disabled, deletions disabled, and linear history required." .

<https://nkllon.com/plaid/security-doc/document/access-control-policy/section/4/block/2/item/2> a secdoc:ListItem ;
    secdoc:itemOrder 2 ;
    secdoc:text "louspringer/chatbot-llm has branch protection on develop, strict status checks enabled, and force pushes and deletions disabled." .

<https://nkllon.com/plaid/security-doc/document/access-control-policy/section/4/block/2/item/3> a secdoc:ListItem ;
    secdoc:itemOrder 3 ;
    secdoc:text "louspringer/chatbot-llm includes a stored branch protection definition requiring one approving review and stale review dismissal." .

<https://nkllon.com/plaid/security-doc/document/access-control-policy/section/4/block/2/item/4> a secdoc:ListItem ;
    secdoc:itemOrder 4 ;
    secdoc:text "nkllon/composable-ai-advisors contains a branch-protection proposal that recommends at least one review and required CI checks." .

<https://nkllon.com/plaid/security-doc/document/access-control-policy/section/4/block/3> a secdoc:ParagraphBlock ;
    secdoc:blockOrder 3 ;
    secdoc:text "Policy expectations:" .

<https://nkllon.com/plaid/security-doc/document/access-control-policy/section/4/block/4> a secdoc:ListBlock ;
    secdoc:blockOrder 4 ;
    secdoc:hasItem <https://nkllon.com/plaid/security-doc/document/access-control-policy/section/4/block/4/item/1>,
        <https://nkllon.com/plaid/security-doc/document/access-control-policy/section/4/block/4/item/2>,
        <https://nkllon.com/plaid/security-doc/document/access-control-policy/section/4/block/4/item/3>,
        <https://nkllon.com/plaid/security-doc/document/access-control-policy/section/4/block/4/item/4>,
        <https://nkllon.com/plaid/security-doc/document/access-control-policy/section/4/block/4/item/5> ;
    secdoc:isOrdered false .

<https://nkllon.com/plaid/security-doc/document/access-control-policy/section/4/block/4/item/1> a secdoc:ListItem ;
    secdoc:itemOrder 1 ;
    secdoc:text "Changes to default branches must occur through pull requests." .

<https://nkllon.com/plaid/security-doc/document/access-control-policy/section/4/block/4/item/2> a secdoc:ListItem ;
    secdoc:itemOrder 2 ;
    secdoc:text "Protected branches must disable force pushes and deletions." .

<https://nkllon.com/plaid/security-doc/document/access-control-policy/section/4/block/4/item/3> a secdoc:ListItem ;
    secdoc:itemOrder 3 ;
    secdoc:text "High-risk repositories must require at least one pull request review before merge." .

<https://nkllon.com/plaid/security-doc/document/access-control-policy/section/4/block/4/item/4> a secdoc:ListItem ;
    secdoc:itemOrder 4 ;
    secdoc:text "High-risk repositories must require status checks for CI workflows that materially validate build, test, and security posture." .

<https://nkllon.com/plaid/security-doc/document/access-control-policy/section/4/block/4/item/5> a secdoc:ListItem ;
    secdoc:itemOrder 5 ;
    secdoc:text "Where a repository does not yet enforce these settings, it must not be represented as fully enforced in external security responses." .

<https://nkllon.com/plaid/security-doc/document/access-control-policy/section/5> a secdoc:Section ;
    secdoc:hasBlock <https://nkllon.com/plaid/security-doc/document/access-control-policy/section/5/block/1> ;
    secdoc:headingLevel 2 ;
    secdoc:sectionOrder 5 ;
    secdoc:title "Administrative access" .

<https://nkllon.com/plaid/security-doc/document/access-control-policy/section/5/block/1> a secdoc:ListBlock ;
    secdoc:blockOrder 1 ;
    secdoc:hasItem <https://nkllon.com/plaid/security-doc/document/access-control-policy/section/5/block/1/item/1>,
        <https://nkllon.com/plaid/security-doc/document/access-control-policy/section/5/block/1/item/2>,
        <https://nkllon.com/plaid/security-doc/document/access-control-policy/section/5/block/1/item/3> ;
    secdoc:isOrdered false .

<https://nkllon.com/plaid/security-doc/document/access-control-policy/section/5/block/1/item/1> a secdoc:ListItem ;
    secdoc:itemOrder 1 ;
    secdoc:text "Repository administration must be restricted to the owner or designated maintainer accounts." .

<https://nkllon.com/plaid/security-doc/document/access-control-policy/section/5/block/1/item/2> a secdoc:ListItem ;
    secdoc:itemOrder 2 ;
    secdoc:text "Administrative actions include branch protection changes, repository visibility changes, secret management, and deployment configuration changes." .

<https://nkllon.com/plaid/security-doc/document/access-control-policy/section/5/block/1/item/3> a secdoc:ListItem ;
    secdoc:itemOrder 3 ;
    secdoc:text "Administrative access must be reviewed at least annually and after any material personnel or ownership change." .

<https://nkllon.com/plaid/security-doc/document/access-control-policy/section/6> a secdoc:Section ;
    secdoc:hasBlock <https://nkllon.com/plaid/security-doc/document/access-control-policy/section/6/block/1> ;
    secdoc:headingLevel 2 ;
    secdoc:sectionOrder 6 ;
    secdoc:title "Service and deployment access" .

<https://nkllon.com/plaid/security-doc/document/access-control-policy/section/6/block/1> a secdoc:ListBlock ;
    secdoc:blockOrder 1 ;
    secdoc:hasItem <https://nkllon.com/plaid/security-doc/document/access-control-policy/section/6/block/1/item/1>,
        <https://nkllon.com/plaid/security-doc/document/access-control-policy/section/6/block/1/item/2>,
        <https://nkllon.com/plaid/security-doc/document/access-control-policy/section/6/block/1/item/3> ;
    secdoc:isOrdered false .

<https://nkllon.com/plaid/security-doc/document/access-control-policy/section/6/block/1/item/1> a secdoc:ListItem ;
    secdoc:itemOrder 1 ;
    secdoc:text "Cloud deployment credentials must not be embedded in code." .

<https://nkllon.com/plaid/security-doc/document/access-control-policy/section/6/block/1/item/2> a secdoc:ListItem ;
    secdoc:itemOrder 2 ;
    secdoc:text "Service accounts or cloud identities must be used for deployment automation where supported." .

<https://nkllon.com/plaid/security-doc/document/access-control-policy/section/6/block/1/item/3> a secdoc:ListItem ;
    secdoc:itemOrder 3 ;
    secdoc:text "Access to cloud consoles, secret stores, and deployment tooling must be restricted to the maintainer and only enabled where operationally required." .

<https://nkllon.com/plaid/security-doc/document/data-protection-policy> a secdoc:Document ;
    secdoc:documentOrder 4 ;
    secdoc:fileStem "DATA_PROTECTION_POLICY" ;
