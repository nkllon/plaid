    secdoc:itemOrder 3 ;
    secdoc:text "Technical investigator: repository owner / maintainer, with external maintainers or providers engaged as needed" .

<https://nkllon.com/plaid/security-doc/document/incident-response-policy/section/4> a secdoc:Section ;
    secdoc:hasBlock <https://nkllon.com/plaid/security-doc/document/incident-response-policy/section/4/block/1> ;
    secdoc:headingLevel 2 ;
    secdoc:sectionOrder 4 ;
    secdoc:title "Severity classification" .

<https://nkllon.com/plaid/security-doc/document/incident-response-policy/section/4/block/1> a secdoc:ListBlock ;
    secdoc:blockOrder 1 ;
    secdoc:hasItem <https://nkllon.com/plaid/security-doc/document/incident-response-policy/section/4/block/1/item/1>,
        <https://nkllon.com/plaid/security-doc/document/incident-response-policy/section/4/block/1/item/2>,
        <https://nkllon.com/plaid/security-doc/document/incident-response-policy/section/4/block/1/item/3>,
        <https://nkllon.com/plaid/security-doc/document/incident-response-policy/section/4/block/1/item/4> ;
    secdoc:isOrdered false .

<https://nkllon.com/plaid/security-doc/document/incident-response-policy/section/4/block/1/item/1> a secdoc:ListItem ;
    secdoc:itemOrder 1 ;
    secdoc:text "Critical: confirmed compromise of production credentials, access tokens, secret stores, or regulated or sensitive financial data." .

<https://nkllon.com/plaid/security-doc/document/incident-response-policy/section/4/block/1/item/2> a secdoc:ListItem ;
    secdoc:itemOrder 2 ;
    secdoc:text "High: likely compromise, active exploitation, or security failure affecting a production integration or protected branch." .

<https://nkllon.com/plaid/security-doc/document/incident-response-policy/section/4/block/1/item/3> a secdoc:ListItem ;
    secdoc:itemOrder 3 ;
    secdoc:text "Medium: validated vulnerability or exposure with limited scope and no evidence of active compromise." .

<https://nkllon.com/plaid/security-doc/document/incident-response-policy/section/4/block/1/item/4> a secdoc:ListItem ;
    secdoc:itemOrder 4 ;
    secdoc:text "Low: security hygiene issue, policy gap, or non-exploited weakness." .

<https://nkllon.com/plaid/security-doc/document/incident-response-policy/section/5> a secdoc:Section ;
