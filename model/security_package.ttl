<https://nkllon.com/plaid/security-doc/document/vulnerability-management/section/6/block/1/item/1> a secdoc:ListItem ;
    secdoc:itemOrder 1 ;
    secdoc:text "Patches must be validated through CI and targeted testing before release." .

<https://nkllon.com/plaid/security-doc/document/vulnerability-management/section/6/block/1/item/2> a secdoc:ListItem ;
    secdoc:itemOrder 2 ;
    secdoc:text "Security-relevant dependency updates must be reviewed for compatibility and regression risk." .

