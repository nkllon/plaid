    secdoc:headingLevel 2 ;
    secdoc:sectionOrder 6 ;
    secdoc:title "Change validation" .

<https://nkllon.com/plaid/security-doc/document/vulnerability-management/section/6/block/1> a secdoc:ListBlock ;
    secdoc:blockOrder 1 ;
    secdoc:hasItem <https://nkllon.com/plaid/security-doc/document/vulnerability-management/section/6/block/1/item/1>,
