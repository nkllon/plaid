    secdoc:partOfPackage <https://nkllon.com/plaid/security-doc/package/plaid-security-package> ;
    secdoc:title "Data Protection Policy" .

<https://nkllon.com/plaid/security-doc/document/data-protection-policy/section/1> a secdoc:Section ;
    secdoc:hasBlock <https://nkllon.com/plaid/security-doc/document/data-protection-policy/section/1/block/1> ;
    secdoc:headingLevel 2 ;
    secdoc:sectionOrder 1 ;
    secdoc:title "Purpose" .

<https://nkllon.com/plaid/security-doc/document/data-protection-policy/section/1/block/1> a secdoc:ParagraphBlock ;
    secdoc:blockOrder 1 ;
    secdoc:text "This policy defines how application, integration, and operational data must be protected across development and deployment environments." .

<https://nkllon.com/plaid/security-doc/document/data-protection-policy/section/10> a secdoc:Section ;
    secdoc:hasBlock <https://nkllon.com/plaid/security-doc/document/data-protection-policy/section/10/block/1> ;
    secdoc:headingLevel 2 ;
    secdoc:sectionOrder 10 ;
    secdoc:title "Retention and deletion" .

<https://nkllon.com/plaid/security-doc/document/data-protection-policy/section/10/block/1> a secdoc:ListBlock ;
    secdoc:blockOrder 1 ;
    secdoc:hasItem <https://nkllon.com/plaid/security-doc/document/data-protection-policy/section/10/block/1/item/1>,
        <https://nkllon.com/plaid/security-doc/document/data-protection-policy/section/10/block/1/item/2>,
        <https://nkllon.com/plaid/security-doc/document/data-protection-policy/section/10/block/1/item/3> ;
    secdoc:isOrdered false .

<https://nkllon.com/plaid/security-doc/document/data-protection-policy/section/10/block/1/item/1> a secdoc:ListItem ;
    secdoc:itemOrder 1 ;
    secdoc:text "Secrets and tokens must be deleted or rotated when no longer required." .

<https://nkllon.com/plaid/security-doc/document/data-protection-policy/section/10/block/1/item/2> a secdoc:ListItem ;
    secdoc:itemOrder 2 ;
    secdoc:text "Logs must avoid storing secrets and must be retained only as long as operationally necessary." .

<https://nkllon.com/plaid/security-doc/document/data-protection-policy/section/10/block/1/item/3> a secdoc:ListItem ;
    secdoc:itemOrder 3 ;
    secdoc:text "Any real customer or financial data introduced into a connected system must be retained only for the minimum period required by application function or legal obligation." .

<https://nkllon.com/plaid/security-doc/document/data-protection-policy/section/11> a secdoc:Section ;
    secdoc:hasBlock <https://nkllon.com/plaid/security-doc/document/data-protection-policy/section/11/block/1> ;
    secdoc:headingLevel 2 ;
    secdoc:sectionOrder 11 ;
    secdoc:title "Review cadence" .

<https://nkllon.com/plaid/security-doc/document/data-protection-policy/section/11/block/1> a secdoc:ListBlock ;
    secdoc:blockOrder 1 ;
    secdoc:hasItem <https://nkllon.com/plaid/security-doc/document/data-protection-policy/section/11/block/1/item/1>,
        <https://nkllon.com/plaid/security-doc/document/data-protection-policy/section/11/block/1/item/2>,
        <https://nkllon.com/plaid/security-doc/document/data-protection-policy/section/11/block/1/item/3> ;
    secdoc:isOrdered false .

<https://nkllon.com/plaid/security-doc/document/data-protection-policy/section/11/block/1/item/1> a secdoc:ListItem ;
    secdoc:itemOrder 1 ;
    secdoc:text "This policy must be reviewed at least annually." .

<https://nkllon.com/plaid/security-doc/document/data-protection-policy/section/11/block/1/item/2> a secdoc:ListItem ;
    secdoc:itemOrder 2 ;
    secdoc:text "High-risk integration repositories must be reviewed at least quarterly." .

<https://nkllon.com/plaid/security-doc/document/data-protection-policy/section/11/block/1/item/3> a secdoc:ListItem ;
    secdoc:itemOrder 3 ;
    secdoc:text "This policy must be updated after any material architecture change, introduction of a new financial-data integration, or security incident." .

<https://nkllon.com/plaid/security-doc/document/data-protection-policy/section/2> a secdoc:Section ;
    secdoc:hasBlock <https://nkllon.com/plaid/security-doc/document/data-protection-policy/section/2/block/1> ;
    secdoc:headingLevel 2 ;
    secdoc:sectionOrder 2 ;
    secdoc:title "Data classification" .

<https://nkllon.com/plaid/security-doc/document/data-protection-policy/section/2/block/1> a secdoc:ListBlock ;
    secdoc:blockOrder 1 ;
    secdoc:hasItem <https://nkllon.com/plaid/security-doc/document/data-protection-policy/section/2/block/1/item/1>,
        <https://nkllon.com/plaid/security-doc/document/data-protection-policy/section/2/block/1/item/2>,
        <https://nkllon.com/plaid/security-doc/document/data-protection-policy/section/2/block/1/item/3>,
        <https://nkllon.com/plaid/security-doc/document/data-protection-policy/section/2/block/1/item/4> ;
    secdoc:isOrdered false .

<https://nkllon.com/plaid/security-doc/document/data-protection-policy/section/2/block/1/item/1> a secdoc:ListItem ;
    secdoc:itemOrder 1 ;
    secdoc:text "Public: open source code, public documentation, test fixtures without secrets, and non-sensitive metadata." .

<https://nkllon.com/plaid/security-doc/document/data-protection-policy/section/2/block/1/item/2> a secdoc:ListItem ;
    secdoc:itemOrder 2 ;
    secdoc:text "Internal: architecture notes, deployment details, issue discussions, and operational metadata not intended for broad public distribution." .

<https://nkllon.com/plaid/security-doc/document/data-protection-policy/section/2/block/1/item/3> a secdoc:ListItem ;
    secdoc:itemOrder 3 ;
    secdoc:text "Confidential: API credentials, tokens, cloud secrets, service account material, private keys, and non-public operational data." .

<https://nkllon.com/plaid/security-doc/document/data-protection-policy/section/2/block/1/item/4> a secdoc:ListItem ;
    secdoc:itemOrder 4 ;
    secdoc:text "Restricted: any real customer data, financial account data, authentication secrets, or regulated data introduced by external integrations." .

<https://nkllon.com/plaid/security-doc/document/data-protection-policy/section/3> a secdoc:Section ;
    secdoc:hasBlock <https://nkllon.com/plaid/security-doc/document/data-protection-policy/section/3/block/1> ;
    secdoc:headingLevel 2 ;
    secdoc:sectionOrder 3 ;
    secdoc:title "Observed data handling posture" .

<https://nkllon.com/plaid/security-doc/document/data-protection-policy/section/3/block/1> a secdoc:ListBlock ;
    secdoc:blockOrder 1 ;
    secdoc:hasItem <https://nkllon.com/plaid/security-doc/document/data-protection-policy/section/3/block/1/item/1>,
        <https://nkllon.com/plaid/security-doc/document/data-protection-policy/section/3/block/1/item/2>,
        <https://nkllon.com/plaid/security-doc/document/data-protection-policy/section/3/block/1/item/3> ;
    secdoc:isOrdered false .

<https://nkllon.com/plaid/security-doc/document/data-protection-policy/section/3/block/1/item/1> a secdoc:ListItem ;
    secdoc:itemOrder 1 ;
    secdoc:text "Reviewed public repositories did not show committed production financial credentials or personal financial data." .

<https://nkllon.com/plaid/security-doc/document/data-protection-policy/section/3/block/1/item/2> a secdoc:ListItem ;
    secdoc:itemOrder 2 ;
    secdoc:text "louspringer/chatbot-llm references sample financial datasets and connected-service credentials for development and deployment." .

<https://nkllon.com/plaid/security-doc/document/data-protection-policy/section/3/block/1/item/3> a secdoc:ListItem ;
    secdoc:itemOrder 3 ;
    secdoc:text "nkllon/sharepoint-mcp processes authenticated SharePoint and Microsoft Graph requests and therefore handles access tokens and application credentials in runtime environments." .

<https://nkllon.com/plaid/security-doc/document/data-protection-policy/section/4> a secdoc:Section ;
    secdoc:hasBlock <https://nkllon.com/plaid/security-doc/document/data-protection-policy/section/4/block/1> ;
    secdoc:headingLevel 2 ;
    secdoc:sectionOrder 4 ;
    secdoc:title "Plaid and financial data scope" .

<https://nkllon.com/plaid/security-doc/document/data-protection-policy/section/4/block/1> a secdoc:ListBlock ;
    secdoc:blockOrder 1 ;
    secdoc:hasItem <https://nkllon.com/plaid/security-doc/document/data-protection-policy/section/4/block/1/item/1>,
        <https://nkllon.com/plaid/security-doc/document/data-protection-policy/section/4/block/1/item/2>,
        <https://nkllon.com/plaid/security-doc/document/data-protection-policy/section/4/block/1/item/3>,
        <https://nkllon.com/plaid/security-doc/document/data-protection-policy/section/4/block/1/item/4> ;
    secdoc:isOrdered false .

<https://nkllon.com/plaid/security-doc/document/data-protection-policy/section/4/block/1/item/1> a secdoc:ListItem ;
    secdoc:itemOrder 1 ;
    secdoc:text "Public repositories must not store Plaid client secrets, access tokens, item identifiers, processor tokens, bank credentials, or raw consumer financial data." .

<https://nkllon.com/plaid/security-doc/document/data-protection-policy/section/4/block/1/item/2> a secdoc:ListItem ;
    secdoc:itemOrder 2 ;
    secdoc:text "Plaid-connected or otherwise financial-data-adjacent integrations must run only in controlled runtime environments." .

<https://nkllon.com/plaid/security-doc/document/data-protection-policy/section/4/block/1/item/3> a secdoc:ListItem ;
    secdoc:itemOrder 3 ;
    secdoc:text "Any Plaid tokens, account data, transaction data, balances, or derived financial records must be confined to managed runtime environments and approved secret or data stores, not public source control." .

<https://nkllon.com/plaid/security-doc/document/data-protection-policy/section/4/block/1/item/4> a secdoc:ListItem ;
    secdoc:itemOrder 4 ;
    secdoc:text "Development environments must use synthetic, sample, or otherwise non-production financial data unless a documented exception is approved by the maintainer." .

<https://nkllon.com/plaid/security-doc/document/data-protection-policy/section/5> a secdoc:Section ;
    secdoc:hasBlock <https://nkllon.com/plaid/security-doc/document/data-protection-policy/section/5/block/1> ;
    secdoc:headingLevel 2 ;
    secdoc:sectionOrder 5 ;
    secdoc:title "Data minimization" .

<https://nkllon.com/plaid/security-doc/document/data-protection-policy/section/5/block/1> a secdoc:ListBlock ;
    secdoc:blockOrder 1 ;
    secdoc:hasItem <https://nkllon.com/plaid/security-doc/document/data-protection-policy/section/5/block/1/item/1>,
        <https://nkllon.com/plaid/security-doc/document/data-protection-policy/section/5/block/1/item/2>,
        <https://nkllon.com/plaid/security-doc/document/data-protection-policy/section/5/block/1/item/3> ;
    secdoc:isOrdered false .

<https://nkllon.com/plaid/security-doc/document/data-protection-policy/section/5/block/1/item/1> a secdoc:ListItem ;
    secdoc:itemOrder 1 ;
    secdoc:text "Repositories must store code, configuration templates, and documentation only." .

<https://nkllon.com/plaid/security-doc/document/data-protection-policy/section/5/block/1/item/2> a secdoc:ListItem ;
    secdoc:itemOrder 2 ;
    secdoc:text "Sensitive values must be provided at runtime through secret stores or environment injection rather than committed to source control." .

<https://nkllon.com/plaid/security-doc/document/data-protection-policy/section/5/block/1/item/3> a secdoc:ListItem ;
    secdoc:itemOrder 3 ;
    secdoc:text "Development and test environments must use synthetic, sample, or non-production data whenever possible." .

<https://nkllon.com/plaid/security-doc/document/data-protection-policy/section/6> a secdoc:Section ;
    secdoc:hasBlock <https://nkllon.com/plaid/security-doc/document/data-protection-policy/section/6/block/1> ;
    secdoc:headingLevel 2 ;
    secdoc:sectionOrder 6 ;
    secdoc:title "Encryption in transit" .

<https://nkllon.com/plaid/security-doc/document/data-protection-policy/section/6/block/1> a secdoc:ListBlock ;
    secdoc:blockOrder 1 ;
    secdoc:hasItem <https://nkllon.com/plaid/security-doc/document/data-protection-policy/section/6/block/1/item/1>,
