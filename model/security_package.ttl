    secdoc:headingLevel 2 ;
    secdoc:sectionOrder 5 ;
    secdoc:title "Sharing and subprocessors" .

<https://nkllon.com/plaid/security-doc/document/privacy-policy/section/5/block/1> a secdoc:ParagraphBlock ;
    secdoc:blockOrder 1 ;
    secdoc:text "Information may be processed by infrastructure and integration providers that support source control, cloud hosting, secret management, logging, and third-party API connectivity." .

<https://nkllon.com/plaid/security-doc/document/privacy-policy/section/5/block/2> a secdoc:ListBlock ;
