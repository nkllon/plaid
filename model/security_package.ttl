<https://nkllon.com/plaid/security-doc/document/open-source-security-model/section/5/block/1/item/1> a secdoc:ListItem ;
    secdoc:itemOrder 1 ;
    secdoc:text "External users may report issues or propose fixes through standard GitHub workflows." .

<https://nkllon.com/plaid/security-doc/document/open-source-security-model/section/5/block/1/item/2> a secdoc:ListItem ;
    secdoc:itemOrder 2 ;
    secdoc:text "The maintainer is responsible for validating, merging, and deploying security-relevant changes." .

<https://nkllon.com/plaid/security-doc/document/open-source-security-model/section/5/block/1/item/3> a secdoc:ListItem ;
    secdoc:itemOrder 3 ;
    secdoc:text "High-risk integration repositories must receive closer review and stronger branch protections than low-risk experimental repositories." .

<https://nkllon.com/plaid/security-doc/document/open-source-security-model/section/6> a secdoc:Section ;
    secdoc:hasBlock <https://nkllon.com/plaid/security-doc/document/open-source-security-model/section/6/block/1> ;
    secdoc:headingLevel 2 ;
    secdoc:sectionOrder 6 ;
    secdoc:title "Review cadence" .

<https://nkllon.com/plaid/security-doc/document/open-source-security-model/section/6/block/1> a secdoc:ListBlock ;
