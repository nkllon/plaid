<https://nkllon.com/plaid/security-doc/document/vulnerability-management/section/5/block/1/item/1> a secdoc:ListItem ;
    secdoc:itemOrder 1 ;
    secdoc:text "Critical: immediate triage and containment, with remediation as quickly as possible" .

<https://nkllon.com/plaid/security-doc/document/vulnerability-management/section/5/block/1/item/2> a secdoc:ListItem ;
    secdoc:itemOrder 2 ;
    secdoc:text "High: target remediation within 7 calendar days where practical" .

<https://nkllon.com/plaid/security-doc/document/vulnerability-management/section/5/block/1/item/3> a secdoc:ListItem ;
    secdoc:itemOrder 3 ;
    secdoc:text "Medium: target remediation within 30 calendar days" .

<https://nkllon.com/plaid/security-doc/document/vulnerability-management/section/5/block/1/item/4> a secdoc:ListItem ;
    secdoc:itemOrder 4 ;
    secdoc:text "Low: resolve in the normal maintenance cycle" .

<https://nkllon.com/plaid/security-doc/document/vulnerability-management/section/6> a secdoc:Section ;
