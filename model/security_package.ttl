    secdoc:isOrdered false .

<https://nkllon.com/plaid/security-doc/document/data-protection-policy/section/6/block/1/item/1> a secdoc:ListItem ;
    secdoc:itemOrder 1 ;
    secdoc:text "External API communication is expected to occur over HTTPS or provider-managed TLS endpoints." .

<https://nkllon.com/plaid/security-doc/document/data-protection-policy/section/6/block/1/item/2> a secdoc:ListItem ;
    secdoc:itemOrder 2 ;
    secdoc:text "Reviewed integrations with GitHub, Microsoft Graph, SharePoint, Google Cloud Run, Azure Key Vault, and cloud control planes inherently rely on TLS-enabled endpoints." .

<https://nkllon.com/plaid/security-doc/document/data-protection-policy/section/7> a secdoc:Section ;
    secdoc:hasBlock <https://nkllon.com/plaid/security-doc/document/data-protection-policy/section/7/block/1> ;
    secdoc:headingLevel 2 ;
    secdoc:sectionOrder 7 ;
    secdoc:title "Encryption at rest" .

<https://nkllon.com/plaid/security-doc/document/data-protection-policy/section/7/block/1> a secdoc:ListBlock ;
    secdoc:blockOrder 1 ;
    secdoc:hasItem <https://nkllon.com/plaid/security-doc/document/data-protection-policy/section/7/block/1/item/1>,
        <https://nkllon.com/plaid/security-doc/document/data-protection-policy/section/7/block/1/item/2>,
