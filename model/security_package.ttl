    secdoc:sectionOrder 1 ;
    secdoc:title "Purpose" .

<https://nkllon.com/plaid/security-doc/document/incident-response-policy/section/1/block/1> a secdoc:ParagraphBlock ;
    secdoc:blockOrder 1 ;
    secdoc:text "This policy defines the minimum incident response process for a solo developer operating open source and integration-focused software." .

<https://nkllon.com/plaid/security-doc/document/incident-response-policy/section/10> a secdoc:Section ;
    secdoc:hasBlock <https://nkllon.com/plaid/security-doc/document/incident-response-policy/section/10/block/1> ;
    secdoc:headingLevel 2 ;
    secdoc:sectionOrder 10 ;
    secdoc:title "Timing expectations" .

<https://nkllon.com/plaid/security-doc/document/incident-response-policy/section/10/block/1> a secdoc:ListBlock ;
    secdoc:blockOrder 1 ;
    secdoc:hasItem <https://nkllon.com/plaid/security-doc/document/incident-response-policy/section/10/block/1/item/1>,
        <https://nkllon.com/plaid/security-doc/document/incident-response-policy/section/10/block/1/item/2>,
        <https://nkllon.com/plaid/security-doc/document/incident-response-policy/section/10/block/1/item/3>,
