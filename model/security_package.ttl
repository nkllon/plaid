    secdoc:title "Security safeguards" .

<https://nkllon.com/plaid/security-doc/document/privacy-policy/section/7/block/1> a secdoc:ListBlock ;
    secdoc:blockOrder 1 ;
    secdoc:hasItem <https://nkllon.com/plaid/security-doc/document/privacy-policy/section/7/block/1/item/1>,
        <https://nkllon.com/plaid/security-doc/document/privacy-policy/section/7/block/1/item/2>,
