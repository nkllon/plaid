<https://nkllon.com/plaid/security-doc/document/readme/section/5/block/1/item/8> a secdoc:ListItem ;
    secdoc:itemOrder 8 ;
    secdoc:text "Reviewed repositories commonly ignore .env, local settings, key material, logs, and virtual environments in .gitignore." .

