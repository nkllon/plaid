    secdoc:itemOrder 5 ;
    secdoc:text "Vulnerability exploitation" .

<https://nkllon.com/plaid/security-doc/document/incident-response-policy/section/2/block/1/item/6> a secdoc:ListItem ;
    secdoc:itemOrder 6 ;
    secdoc:text "Malicious dependency or supply chain event" .

<https://nkllon.com/plaid/security-doc/document/incident-response-policy/section/2/block/1/item/7> a secdoc:ListItem ;
    secdoc:itemOrder 7 ;
    secdoc:text "Material service outage affecting security controls" .

