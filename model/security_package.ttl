<https://nkllon.com/plaid/security-doc/document/open-source-security-model/section/6/block/1/item/1> a secdoc:ListItem ;
    secdoc:itemOrder 1 ;
    secdoc:text "This model must be reviewed at least annually and after any material change to financial-data integrations or deployment boundaries." .

