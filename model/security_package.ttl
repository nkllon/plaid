    secdoc:hasBlock <https://nkllon.com/plaid/security-doc/document/vulnerability-management/section/5/block/1> ;
    secdoc:headingLevel 2 ;
    secdoc:sectionOrder 5 ;
    secdoc:title "Remediation targets" .

<https://nkllon.com/plaid/security-doc/document/vulnerability-management/section/5/block/1> a secdoc:ListBlock ;
    secdoc:blockOrder 1 ;
    secdoc:hasItem <https://nkllon.com/plaid/security-doc/document/vulnerability-management/section/5/block/1/item/1>,
