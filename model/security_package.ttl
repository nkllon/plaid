    secdoc:itemOrder 1 ;
    secdoc:text "Record root cause, impact, actions taken, and follow-up improvements." .

<https://nkllon.com/plaid/security-doc/document/incident-response-policy/section/12/block/1/item/2> a secdoc:ListItem ;
    secdoc:itemOrder 2 ;
    secdoc:text "Corrective actions must be tracked to completion." .

<https://nkllon.com/plaid/security-doc/document/incident-response-policy/section/12/block/1/item/3> a secdoc:ListItem ;
    secdoc:itemOrder 3 ;
    secdoc:text "Policy, CI, branch protections, deployment controls, and secret handling practices must be updated if the incident reveals control gaps." .

