    secdoc:isOrdered false .

<https://nkllon.com/plaid/security-doc/document/incident-response-policy/section/10/block/1/item/1> a secdoc:ListItem ;
    secdoc:itemOrder 1 ;
    secdoc:text "Critical credential exposure: begin containment immediately." .

<https://nkllon.com/plaid/security-doc/document/incident-response-policy/section/10/block/1/item/2> a secdoc:ListItem ;
    secdoc:itemOrder 2 ;
    secdoc:text "High-severity confirmed incident: investigate and remediate as soon as practical, targeting same-day triage." .

<https://nkllon.com/plaid/security-doc/document/incident-response-policy/section/10/block/1/item/3> a secdoc:ListItem ;
    secdoc:itemOrder 3 ;
    secdoc:text "Lower-severity events: address in the next normal maintenance cycle unless exploitation risk is elevated." .

<https://nkllon.com/plaid/security-doc/document/incident-response-policy/section/10/block/1/item/4> a secdoc:ListItem ;
    secdoc:itemOrder 4 ;
    secdoc:text "Exposed Plaid or equivalent production secrets must be rotated immediately upon confirmation or strong suspicion of compromise." .

<https://nkllon.com/plaid/security-doc/document/incident-response-policy/section/11> a secdoc:Section ;
    secdoc:hasBlock <https://nkllon.com/plaid/security-doc/document/incident-response-policy/section/11/block/1> ;
    secdoc:headingLevel 2 ;
    secdoc:sectionOrder 11 ;
    secdoc:title "Evidence retention" .

<https://nkllon.com/plaid/security-doc/document/incident-response-policy/section/11/block/1> a secdoc:ListBlock ;
