    secdoc:hasItem <https://nkllon.com/plaid/security-doc/document/readme/section/10/block/1/item/1>,
        <https://nkllon.com/plaid/security-doc/document/readme/section/10/block/1/item/2>,
        <https://nkllon.com/plaid/security-doc/document/readme/section/10/block/1/item/3>,
        <https://nkllon.com/plaid/security-doc/document/readme/section/10/block/1/item/4>,
        <https://nkllon.com/plaid/security-doc/document/readme/section/10/block/1/item/5>,
        <https://nkllon.com/plaid/security-doc/document/readme/section/10/block/1/item/6> ;
    secdoc:isOrdered false .

<https://nkllon.com/plaid/security-doc/document/readme/section/10/block/1/item/1> a secdoc:ListItem ;
    secdoc:itemOrder 1 ;
    secdoc:text "No reviewed public repository stores production Plaid credentials, banking credentials, or personal financial account data." .

<https://nkllon.com/plaid/security-doc/document/readme/section/10/block/1/item/2> a secdoc:ListItem ;
    secdoc:itemOrder 2 ;
    secdoc:text "No evidence was found that public repositories intentionally store raw consumer financial data." .

<https://nkllon.com/plaid/security-doc/document/readme/section/10/block/1/item/3> a secdoc:ListItem ;
    secdoc:itemOrder 3 ;
    secdoc:text "louspringer/chatbot-llm references a sample financial dataset and credentials for Snowflake and Microsoft Teams integrations. This repository is best classified as HIGH risk because it handles application credentials and may process business data in connected environments." .

<https://nkllon.com/plaid/security-doc/document/readme/section/10/block/1/item/4> a secdoc:ListItem ;
    secdoc:itemOrder 4 ;
    secdoc:text "nkllon/sharepoint-mcp is best classified as HIGH risk because it handles OAuth-style application credentials and access tokens for Microsoft Graph and SharePoint." .

<https://nkllon.com/plaid/security-doc/document/readme/section/10/block/1/item/5> a secdoc:ListItem ;
    secdoc:itemOrder 5 ;
    secdoc:text "Infrastructure repositories such as louspringer/azure-databricks-terraform and louspringer/ecs-microservice-terraform are classified MEDIUM because they define deployment patterns and secret-management expectations without showing consumer financial credential storage in-repo." .

<https://nkllon.com/plaid/security-doc/document/readme/section/10/block/1/item/6> a secdoc:ListItem ;
    secdoc:itemOrder 6 ;
    secdoc:text "Most remaining repositories are LOW risk because they are libraries, experiments, docs, or tools with no observed handling of sensitive financial data." .

<https://nkllon.com/plaid/security-doc/document/readme/section/11> a secdoc:Section ;
    secdoc:hasBlock <https://nkllon.com/plaid/security-doc/document/readme/section/11/block/1> ;
    secdoc:headingLevel 2 ;
    secdoc:sectionOrder 11 ;
    secdoc:title "Suggested repository location" .

<https://nkllon.com/plaid/security-doc/document/readme/section/11/block/1> a secdoc:ParagraphBlock ;
    secdoc:blockOrder 1 ;
    secdoc:text "If a single authoritative location is desired, keep this package in a top-level `security/` directory in the primary integration or governance repository and link to it from `README.md` and `SECURITY.md`. For public discoverability, `louspringer/chatbot-llm` or a dedicated governance repository under `nkllon` would be reasonable homes." .

<https://nkllon.com/plaid/security-doc/document/readme/section/12> a secdoc:Section ;
    secdoc:hasBlock <https://nkllon.com/plaid/security-doc/document/readme/section/12/block/1> ;
    secdoc:headingLevel 2 ;
    secdoc:sectionOrder 12 ;
    secdoc:title "Inventory notes" .

<https://nkllon.com/plaid/security-doc/document/readme/section/12/block/1> a secdoc:ListBlock ;
    secdoc:blockOrder 1 ;
    secdoc:hasItem <https://nkllon.com/plaid/security-doc/document/readme/section/12/block/1/item/1>,
        <https://nkllon.com/plaid/security-doc/document/readme/section/12/block/1/item/2>,
        <https://nkllon.com/plaid/security-doc/document/readme/section/12/block/1/item/3> ;
    secdoc:isOrdered false .

<https://nkllon.com/plaid/security-doc/document/readme/section/12/block/1/item/1> a secdoc:ListItem ;
    secdoc:itemOrder 1 ;
    secdoc:text "The inventory below is a complete enumeration of repositories returned by GitHub for nkllon and louspringer during this review." .

<https://nkllon.com/plaid/security-doc/document/readme/section/12/block/1/item/2> a secdoc:ListItem ;
    secdoc:itemOrder 2 ;
    secdoc:text "Classification and risk values are conservative and intended for questionnaire support, not as formal audit labels." .

<https://nkllon.com/plaid/security-doc/document/readme/section/12/block/1/item/3> a secdoc:ListItem ;
    secdoc:itemOrder 3 ;
    secdoc:text "Where a repository was not deeply inspected, classification is based on repository metadata and naming signals." .

