<https://nkllon.com/plaid/security-doc/document/privacy-policy/section/4/block/1/item/1> a secdoc:ListItem ;
    secdoc:itemOrder 1 ;
    secdoc:text "Only the minimum information necessary for the relevant integration or operational function may be processed." .

<https://nkllon.com/plaid/security-doc/document/privacy-policy/section/4/block/1/item/2> a secdoc:ListItem ;
    secdoc:itemOrder 2 ;
    secdoc:text "Public repositories must not contain live Plaid credentials, access tokens, bank credentials, or raw consumer financial data." .

<https://nkllon.com/plaid/security-doc/document/privacy-policy/section/4/block/1/item/3> a secdoc:ListItem ;
    secdoc:itemOrder 3 ;
    secdoc:text "Development and test environments must use synthetic, sample, or otherwise non-production financial data whenever possible." .

<https://nkllon.com/plaid/security-doc/document/privacy-policy/section/5> a secdoc:Section ;
    secdoc:hasBlock <https://nkllon.com/plaid/security-doc/document/privacy-policy/section/5/block/1>,
