    secdoc:isOrdered false .

<https://nkllon.com/plaid/security-doc/document/privacy-policy/section/7/block/1/item/1> a secdoc:ListItem ;
    secdoc:itemOrder 1 ;
    secdoc:text "Encryption in transit is required through HTTPS or provider-managed TLS endpoints." .

<https://nkllon.com/plaid/security-doc/document/privacy-policy/section/7/block/1/item/2> a secdoc:ListItem ;
    secdoc:itemOrder 2 ;
    secdoc:text "Managed secret stores or equivalent approved secure tooling must be used for production secrets." .

<https://nkllon.com/plaid/security-doc/document/privacy-policy/section/7/block/1/item/3> a secdoc:ListItem ;
    secdoc:itemOrder 3 ;
    secdoc:text "Access tokens, authorization headers, private keys, and plaintext secrets must never be written to logs." .

<https://nkllon.com/plaid/security-doc/document/privacy-policy/section/7/block/1/item/4> a secdoc:ListItem ;
    secdoc:itemOrder 4 ;
    secdoc:text "Plaid-connected and other financial-data-adjacent integrations must run only in controlled runtime environments." .

<https://nkllon.com/plaid/security-doc/document/privacy-policy/section/8> a secdoc:Section ;
    secdoc:hasBlock <https://nkllon.com/plaid/security-doc/document/privacy-policy/section/8/block/1>,
