    secdoc:headingLevel 3 ;
    secdoc:sectionOrder 6 ;
    secdoc:title "2. Containment" .

<https://nkllon.com/plaid/security-doc/document/incident-response-policy/section/6/block/1> a secdoc:ListBlock ;
    secdoc:blockOrder 1 ;
    secdoc:hasItem <https://nkllon.com/plaid/security-doc/document/incident-response-policy/section/6/block/1/item/1>,
        <https://nkllon.com/plaid/security-doc/document/incident-response-policy/section/6/block/1/item/2>,
        <https://nkllon.com/plaid/security-doc/document/incident-response-policy/section/6/block/1/item/3>,
        <https://nkllon.com/plaid/security-doc/document/incident-response-policy/section/6/block/1/item/4> ;
