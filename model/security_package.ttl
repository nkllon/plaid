    secdoc:itemOrder 1 ;
    secdoc:text "Incident commander: repository owner / maintainer" .

<https://nkllon.com/plaid/security-doc/document/incident-response-policy/section/3/block/1/item/2> a secdoc:ListItem ;
    secdoc:itemOrder 2 ;
    secdoc:text "Communications owner: repository owner / maintainer" .

