<https://nkllon.com/plaid/security-doc/document/access-control-policy> a secdoc:Document ;
    secdoc:documentOrder 3 ;
    secdoc:fileStem "ACCESS_CONTROL_POLICY" ;
    secdoc:hasSection <https://nkllon.com/plaid/security-doc/document/access-control-policy/section/1>,
