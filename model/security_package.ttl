    secdoc:hasItem <https://nkllon.com/plaid/security-doc/document/incident-response-policy/section/11/block/1/item/1> ;
    secdoc:isOrdered false .

<https://nkllon.com/plaid/security-doc/document/incident-response-policy/section/11/block/1/item/1> a secdoc:ListItem ;
    secdoc:itemOrder 1 ;
    secdoc:text "Preserve relevant commits, logs, workflow outputs, and screenshots as needed to support investigation and post-incident review." .

<https://nkllon.com/plaid/security-doc/document/incident-response-policy/section/12> a secdoc:Section ;
    secdoc:hasBlock <https://nkllon.com/plaid/security-doc/document/incident-response-policy/section/12/block/1> ;
    secdoc:headingLevel 2 ;
    secdoc:sectionOrder 12 ;
    secdoc:title "Post-incident review" .

<https://nkllon.com/plaid/security-doc/document/incident-response-policy/section/12/block/1> a secdoc:ListBlock ;
    secdoc:blockOrder 1 ;
    secdoc:hasItem <https://nkllon.com/plaid/security-doc/document/incident-response-policy/section/12/block/1/item/1>,
