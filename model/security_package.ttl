<https://nkllon.com/plaid/security-doc/document/vulnerability-management/section/7/block/1/item/1> a secdoc:ListItem ;
    secdoc:itemOrder 1 ;
    secdoc:text "If remediation is delayed due to compatibility, platform, or maintainer capacity constraints, the risk and compensating controls must be documented in the repository issue tracker or project notes." .

