<https://nkllon.com/plaid/security-doc/document/incident-response-policy/section/5/block/1/item/1> a secdoc:ListItem ;
    secdoc:itemOrder 1 ;
    secdoc:text "Detect incidents through GitHub alerts, CI failures, cloud-provider alerts, issue reports, user reports, or manual review." .

<https://nkllon.com/plaid/security-doc/document/incident-response-policy/section/6> a secdoc:Section ;
