<https://nkllon.com/plaid/security-doc/document/security-program/section/1> a secdoc:Section ;
    secdoc:hasBlock <https://nkllon.com/plaid/security-doc/document/security-program/section/1/block/1> ;
    secdoc:headingLevel 2 ;
    secdoc:sectionOrder 1 ;
    secdoc:title "Purpose" .

<https://nkllon.com/plaid/security-doc/document/security-program/section/1/block/1> a secdoc:ParagraphBlock ;
    secdoc:blockOrder 1 ;
    secdoc:text "This document describes the security program used for software developed and operated by a solo developer across the `nkllon` organization and the `louspringer` GitHub account. The program is intentionally lightweight, but it is structured to provide clear ownership, repeatable security practices, and defensible controls for applications and integrations adjacent to financial-data workflows." .

<https://nkllon.com/plaid/security-doc/document/security-program/section/2> a secdoc:Section ;
    secdoc:hasBlock <https://nkllon.com/plaid/security-doc/document/security-program/section/2/block/1> ;
    secdoc:headingLevel 2 ;
    secdoc:sectionOrder 2 ;
    secdoc:title "Governance model" .

<https://nkllon.com/plaid/security-doc/document/security-program/section/2/block/1> a secdoc:ListBlock ;
    secdoc:blockOrder 1 ;
    secdoc:hasItem <https://nkllon.com/plaid/security-doc/document/security-program/section/2/block/1/item/1>,
        <https://nkllon.com/plaid/security-doc/document/security-program/section/2/block/1/item/2>,
        <https://nkllon.com/plaid/security-doc/document/security-program/section/2/block/1/item/3>,
        <https://nkllon.com/plaid/security-doc/document/security-program/section/2/block/1/item/4> ;
    secdoc:isOrdered false .

<https://nkllon.com/plaid/security-doc/document/security-program/section/2/block/1/item/1> a secdoc:ListItem ;
    secdoc:itemOrder 1 ;
    secdoc:text "Security ownership rests with the repository owner and maintainer." .

<https://nkllon.com/plaid/security-doc/document/security-program/section/2/block/1/item/2> a secdoc:ListItem ;
    secdoc:itemOrder 2 ;
    secdoc:text "Changes are managed primarily through GitHub repositories, pull requests, and repository-level controls." .

<https://nkllon.com/plaid/security-doc/document/security-program/section/2/block/1/item/3> a secdoc:ListItem ;
    secdoc:itemOrder 3 ;
    secdoc:text "Public repositories rely on transparency, issue tracking, CI validation, and dependency monitoring as core control mechanisms." .

<https://nkllon.com/plaid/security-doc/document/security-program/section/2/block/1/item/4> a secdoc:ListItem ;
    secdoc:itemOrder 4 ;
    secdoc:text "Private repositories are used when integrations require deployment details, environment configuration, or operational secrets that must not be exposed publicly." .

<https://nkllon.com/plaid/security-doc/document/security-program/section/3> a secdoc:Section ;
    secdoc:hasBlock <https://nkllon.com/plaid/security-doc/document/security-program/section/3/block/1> ;
    secdoc:headingLevel 2 ;
    secdoc:sectionOrder 3 ;
