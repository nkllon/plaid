<https://nkllon.com/plaid/security-doc/document/privacy-policy/section/3/block/1/item/1> a secdoc:ListItem ;
    secdoc:itemOrder 1 ;
    secdoc:text "To develop, test, secure, and operate software integrations." .

<https://nkllon.com/plaid/security-doc/document/privacy-policy/section/3/block/1/item/2> a secdoc:ListItem ;
    secdoc:itemOrder 2 ;
    secdoc:text "To authenticate to third-party services and maintain service availability." .

<https://nkllon.com/plaid/security-doc/document/privacy-policy/section/3/block/1/item/3> a secdoc:ListItem ;
    secdoc:itemOrder 3 ;
    secdoc:text "To investigate incidents, perform debugging, and meet security obligations." .

<https://nkllon.com/plaid/security-doc/document/privacy-policy/section/3/block/1/item/4> a secdoc:ListItem ;
    secdoc:itemOrder 4 ;
    secdoc:text "To comply with legal obligations or valid requests from regulators or service providers where applicable." .

<https://nkllon.com/plaid/security-doc/document/privacy-policy/section/4> a secdoc:Section ;
