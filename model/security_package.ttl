<https://nkllon.com/plaid/security-doc/document/security-program/section/3/block/1/item/1> a secdoc:ListItem ;
    secdoc:itemOrder 1 ;
    secdoc:text "Prevent exposure of credentials, access tokens, and secret material." .

<https://nkllon.com/plaid/security-doc/document/security-program/section/3/block/1/item/2> a secdoc:ListItem ;
    secdoc:itemOrder 2 ;
    secdoc:text "Minimize storage and retention of sensitive data." .

<https://nkllon.com/plaid/security-doc/document/security-program/section/3/block/1/item/3> a secdoc:ListItem ;
    secdoc:itemOrder 3 ;
    secdoc:text "Use trusted cloud-provider controls where cloud deployment is required." .

<https://nkllon.com/plaid/security-doc/document/security-program/section/3/block/1/item/4> a secdoc:ListItem ;
    secdoc:itemOrder 4 ;
    secdoc:text "Detect vulnerable dependencies and insecure code changes early through CI and repository tooling." .

<https://nkllon.com/plaid/security-doc/document/security-program/section/3/block/1/item/5> a secdoc:ListItem ;
    secdoc:itemOrder 5 ;
    secdoc:text "Maintain a documented response process for incidents, vulnerabilities, and reported security issues." .

