<https://nkllon.com/plaid/security-doc/document/readme/section/8/block/2/item/4> a secdoc:ListItem ;
    secdoc:itemOrder 4 ;
    secdoc:text "External integration providers: Microsoft Graph, SharePoint, Snowflake" .

<https://nkllon.com/plaid/security-doc/document/readme/section/8/block/3> a secdoc:ParagraphBlock ;
    secdoc:blockOrder 3 ;
    secdoc:text "These providers are used as infrastructure or integration components. Sensitive runtime credentials must remain in provider-managed secret stores or equivalent approved systems and must not be committed to public repositories." .

