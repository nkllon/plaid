    secdoc:itemOrder 1 ;
    secdoc:text "GitHub and GitHub Actions for source control and CI/CD." .

<https://nkllon.com/plaid/security-doc/document/privacy-policy/section/5/block/2/item/2> a secdoc:ListItem ;
    secdoc:itemOrder 2 ;
    secdoc:text "Cloud providers and managed secret stores such as Google Cloud Run, GCP Secret Manager, Azure Key Vault, Azure Databricks, and documented AWS patterns." .

<https://nkllon.com/plaid/security-doc/document/privacy-policy/section/5/block/2/item/3> a secdoc:ListItem ;
    secdoc:itemOrder 3 ;
    secdoc:text "Integration providers such as Plaid, Microsoft Graph, SharePoint, and Snowflake when used in runtime environments." .

<https://nkllon.com/plaid/security-doc/document/privacy-policy/section/6> a secdoc:Section ;
    secdoc:hasBlock <https://nkllon.com/plaid/security-doc/document/privacy-policy/section/6/block/1> ;
    secdoc:headingLevel 2 ;
    secdoc:sectionOrder 6 ;
